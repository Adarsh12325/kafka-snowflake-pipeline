# ==============================================================================
# Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# Kafka Cluster Configuration
KAFKA_BROKER_ADDRESS=kafka:29092
KAFKA_TOPIC_RAW_EVENTS=raw_events
KAFKA_TOPIC_FAILED_EVENTS=failed_events

# Producer Settings
PRODUCER_RATE_SECONDS=1

# Consumer Ingestion & Retry Settings
MAX_RETRIES=3
RETRY_BACKOFF_BASE_SECONDS=1
BATCH_SIZE=100

# Snowflake Connection Configuration
# (Required for production/staging loading. Mocks will be used in unit tests.)
SNOWFLAKE_ACCOUNT=your_snowflake_account_identifier
SNOWFLAKE_USER=YOUR_USERNAME
SNOWFLAKE_PASSWORD=YOUR_SECURE_PASSWORD
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=INGEST_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_TABLE_PROCESSED_EVENTS=events_processed

# Resilient Failure Simulation Flag
# Set to 'true' to simulate temporary Snowflake insertion failures for testing retries and DLQ
SIMULATE_SNOWFLAKE_FAILURE=false
