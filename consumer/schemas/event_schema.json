{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IngestedEventSchema",
  "type": "object",
  "required": ["event_id", "event_timestamp", "event_type", "payload"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
